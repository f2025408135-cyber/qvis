# =======================================================
# QVis 10/10 Production-Grade Default Configuration
# MUST RENAME TO .env.production BEFORE LAUNCH
# =======================================================

# Core Security Enforcements
QVIS_AUTH_ENABLED=true
QVIS_DEMO_MODE=false

# High-Entropy Secrets (Must override in production)
QVIS_JWT_SECRET=generate-me-using-openssl-rand-hex-32
QVIS_ENCRYPTION_PASSWORD=super-secret-password-12345!
QVIS_ENCRYPTION_SALT=generate-me-using-openssl-rand-hex-16

# Persistence Paths
QVIS_DATABASE_URL=postgresql+asyncpg://qvis:secure_password@postgres:5432/qvis_db
QVIS_REDIS_URL=redis://redis:6379/0

# Operational Integrity
QVIS_LOG_LEVEL=INFO
QVIS_LOG_FORMAT=json
QVIS_RATE_LIMIT=100/60
