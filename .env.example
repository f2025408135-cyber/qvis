# ─── QVis Configuration ─────────────────────────────────────────────
# Copy to .env and fill in values as needed.

# IBM Quantum
IBM_QUANTUM_TOKEN=
DEMO_MODE=true
UPDATE_INTERVAL_SECONDS=30

# AWS Braket (optional — enables multi-platform)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Azure Quantum (optional — enables multi-platform)
AZURE_QUANTUM_SUBSCRIPTION_ID=

# Security
AUTH_ENABLED=false
API_KEY=
RATE_LIMIT=60/60

# Logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Options: console (human-readable), json (for log aggregation pipelines)
LOG_FORMAT=console

# GitHub Scanner (optional — scans for leaked tokens)
GITHUB_TOKEN=

# Alerting (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
WEBHOOK_URL=

# Metrics
METRICS_ENABLED=true          # Expose /metrics endpoint
